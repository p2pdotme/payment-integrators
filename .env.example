# ──────────────────────────────────────────────
# payment-integrators — environment variables
# ──────────────────────────────────────────────
# Copy to .env and fill in.
# NEVER commit .env — it contains private keys.
# ──────────────────────────────────────────────

# ─── Networks ─────────────────────────────────
BASE_RPC=https://mainnet.base.org
BASE_SEPOLIA_RPC=https://sepolia.base.org

# ─── Deployer ────────────────────────────────
# Use one of these — DEPLOYER_PRIVATE_KEY takes precedence.
DEPLOYER_PRIVATE_KEY=
MNEMONIC_KEY=

# ─── Verification ─────────────────────────────
BASESCAN_API_KEY=

# ─── Protocol addresses (filled per network) ──
# The P2P Diamond proxy address for the target network.
DIAMOND_ADDRESS=
# USDC on the target network.
USDC_ADDRESS=

# ─── Deploy params (optional) ─────────────────
BASE_TX_LIMIT=50000000        # 6 decimals — default 50 USDC
DAILY_TX_COUNT_LIMIT=10

# ─── LotPot-specific (only if deploying LotPot) ─
MEGAPOT_ADDRESS=
BATCH_FACILITATOR_ADDRESS=
JACKPOT_NFT_ADDRESS=
SOURCE_TAG=lotpot
